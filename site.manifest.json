{
  "host": "peagen.com",
  "zone": "peagen.com",
  "repository": "swarmauri/peagen-com",
  "siteKind": "mdwrk-lander",
  "orchestrator": "npmctl",
  "dnsProvider": "namecheap",
  "deployment": "self-hosted-docker",
  "dockerService": "peagen-com",
  "records": [
    {
      "type": "A",
      "host": "@",
      "value": "SELF_HOSTED_DOCKER_IP",
      "ttl": 300
    },
    {
      "type": "CNAME",
      "host": "www",
      "value": "peagen.com",
      "ttl": 300
    }
  ],
  "proxyManager": {
    "provider": "nginx-proxy-manager",
    "apiEndpoint": "https://nginx.bz23.xyz/"
  }
}
